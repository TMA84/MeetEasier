#EWS_USERNAME=
#EWS_PASSWORD=
#EWS_URI=

#OAUTH_CLIENT_ID=
# Tenant ID (preferred) or full URL (https://login.microsoftonline.com/<tenant-id>)
#OAUTH_AUTHORITY=
#OAUTH_CLIENT_SECRET=

#SEARCH_USE_GRAPHAPI=true
#SEARCH_MAXDAYS=7
#SEARCH_MAXROOMLISTS=5
#SEARCH_MAXROOMS=50
#SEARCH_MAXITEMS=100
#SEARCH_POLL_INTERVAL_MS=15000

PORT=

# Security: upgrade-insecure-requests CSP directive (optional)
# Set to true when running behind HTTPS reverse proxy in production
# Default: disabled (required for local HTTP development, especially Safari)
# CSP_UPGRADE_INSECURE=true

# Startup validation (optional)
# STARTUP_VALIDATION_STRICT=false

# API rate limits (optional)
# RATE_LIMIT_API_WINDOW_MS=60000
# RATE_LIMIT_API_MAX=300
# RATE_LIMIT_WRITE_WINDOW_MS=60000
# RATE_LIMIT_WRITE_MAX=60
# RATE_LIMIT_AUTH_WINDOW_MS=60000
# RATE_LIMIT_AUTH_MAX=30

# Graph webhook mode (optional)
# Enables /api/graph/webhook and switches polling to a long fallback interval
# GRAPH_WEBHOOK_ENABLED=false
# GRAPH_WEBHOOK_CLIENT_STATE=your-random-client-state
# GRAPH_WEBHOOK_ALLOWED_IPS=20.190.128.0/18,20.190.160.0/19

# Maintenance mode defaults (optional)
# MAINTENANCE_MODE=false
# MAINTENANCE_MESSAGE=System is in maintenance mode. Please try again later.

# Check-in / no-show handling (optional)
# CHECKIN_ENABLED=true
# CHECKIN_REQUIRED_FOR_EXTERNAL=true
# CHECKIN_EARLY_MINUTES=5
# CHECKIN_WINDOW_MINUTES=10
# CHECKIN_AUTO_RELEASE_NO_SHOW=true

# WiFi Configuration
# Note: WiFi settings are now managed via API at /api/wifi
# Access the admin panel at: http://your-server:8080/admin
# Initial values can be set in data/wifi-config.json or via environment variables below

# Admin Panel API Security Token
# Generate a secure token: openssl rand -hex 32
# Optional override. If not set, default token `change-me-admin-token` is used.
# You can also change the token via Admin panel (Operations -> Admin API Token).
# API_TOKEN=your-secure-token-here

# WiFi Default Settings (optional)
# These values are used if no configuration file exists
# When WIFI_SSID is set, WiFi configuration section will be hidden in admin panel
# WIFI_SSID=Guest WiFi
# WIFI_PASSWORD=

# Logo Configuration (optional)
# Default logo URLs for dark and light themes
# When LOGO_DARK_URL or LOGO_LIGHT_URL is set, logo configuration section will be hidden in admin panel
# LOGO_DARK_URL=../img/logo.B.png
# LOGO_LIGHT_URL=../img/logo.W.png

# Sidebar Configuration (optional)
# Control what is displayed in the room display sidebar
# When any SIDEBAR_* variable is set, sidebar configuration section will be hidden in admin panel
# SIDEBAR_SHOW_WIFI=true
# SIDEBAR_SHOW_UPCOMING=false
# SIDEBAR_SHOW_TITLES=false

# Booking Configuration (optional)
# Enable or disable the room booking feature
# When ENABLE_BOOKING is set, booking configuration section will be hidden in admin panel
# Default: true (enabled)
# ENABLE_BOOKING=true

# Required Permissions for Room Booking:
# 
# For Microsoft Graph API:
# - Application must have Calendars.ReadWrite permission
# - Room mailboxes must allow direct booking or grant the application permission
# - Bookings are created directly in the room's calendar (room is the organizer)
#
# For EWS:
# - Service account must have ApplicationImpersonation role in Exchange
# - This allows the service to create events in room calendars on behalf of the room
# - Bookings are created directly in the room's calendar using impersonation

